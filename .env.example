# --- VLM (for ingredient identification) ---
LLM_PROVIDER=openrouter       # anthropic | openai | gemini | openrouter
LLM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free     # provider-specific model id
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=


# LLM_PROVIDER=
# LLM_MODEL==
OPENROUTER_API_KEY=your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REASONING_ENABLED=false
OPENROUTER_REASONING_EXCLUDE=false

# --- Nutrition provider ---
NUTRITION_PROVIDER=usda
USDA_API_KEY=  # free key from https://fdc.nal.usda.gov/api-key-signup

# --- SE-layer settings (you will populate these) ---
LOG_LEVEL=INFO
# PostgreSQL connection string. For asyncpg, use the postgresql+asyncpg:// scheme.
# Spin up a local server with docker: `docker run -d --name pg -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16`
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/foodanalyzer
NUTRITION_CACHE_TTL_SECONDS=86400
MAX_IMAGE_SIZE_MB=5
MAX_CONCURRENCY=10
RETRY_ATTEMPTS=3
UPLOAD_DIR=uploads
OFFLINE_MODE=false
HTTP_PORT=8000